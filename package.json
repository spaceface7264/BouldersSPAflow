{
  "name": "boulders-membership-flow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "npx tsc && npx vite build",
    "prod": "npx tsc && npx vite build",
    "lint": "npx eslint functions --ext .ts",
    "preview": "npx vite preview",
    "deploy": "npm run build && npx wrangler pages deploy . --project-name=boulders-membership-flow",
    "deploy:worker": "npx wrangler deploy --assets=./dist",
    "deploy:cloudflare": "npm run build && npx wrangler deploy --assets=./dist"
  },
  "dependencies": {
    "@sentry/browser": "^10.34.0",
    "@sentry/vite-plugin": "^4.6.2",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.3.1",
    "leaflet": "^1.9.4",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "autoprefixer": "^10.4.16",
    "baseline-browser-mapping": "^2.9.15",
    "eslint": "^8.55.0",
    "eslint-import-resolver-typescript": "^3.5.2",
    "eslint-plugin-import": "^2.31.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^6.4.1"
  }
}
